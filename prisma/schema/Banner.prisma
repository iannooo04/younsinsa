model Banner {
  id           String    @id @default(uuid())
  title        String
  description  String?
  pcImage      String
  mobileImage  String
  linkUrl      String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  startDate    DateTime?
  endDate      DateTime?
  targetGroup  String    // e.g., 'main', 'shoes', 'bag'
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
